TypeScript
export const usePlayerStore = defineStore('player', {
  state: () => ({
    // ... 原有状态
    playlist: [] as any[],     // 当前播放队列
    currentIndex: -1,          // 当前播放索引
    playMode: 'sequence',      // 播放模式: sequence(顺序), loop(单曲), random(随机)
  }),
  
  actions: {
    // 播放整个歌单/列表
    setPlaylist(list: any[], index = 0) {
      this.playlist = list;
      this.currentIndex = index;
      this.playTrack(this.playlist[index]);
    },

    // 下一首
    next() {
      if (this.playlist.length === 0) return;
      let nextIndex = this.currentIndex + 1;
      if (nextIndex >= this.playlist.length) nextIndex = 0; // 循环回第一首
      this.currentIndex = nextIndex;
      this.playTrack(this.playlist[this.currentIndex]);
    },

    // 上一首
    prev() {
      if (this.playlist.length === 0) return;
      let prevIndex = this.currentIndex - 1;
      if (prevIndex < 0) prevIndex = this.playlist.length - 1; // 循环回最后一首
      this.currentIndex = prevIndex;
      this.playTrack(this.playlist[this.currentIndex]);
    },

    // 自动切歌逻辑 (在 playTrack 的 audio 初始化中调用)
    initAudioEvents() {
      this.audio.onended = () => {
        if (this.playMode === 'loop') {
          this.audio.play(); // 单曲循环
        } else {
          this.next();
        }
      };
    }
  }
});
