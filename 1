使用 Electron 的 globalShortcut 监听多媒体按键。

TypeScript
import { app, globalShortcut, BrowserWindow } from 'electron';

app.whenReady().then(() => {
  const win = BrowserWindow.getAllWindows()[0];

  // 1. 监听 播放/暂停
  globalShortcut.register('MediaPlayPause', () => {
    win.webContents.send('player-control', 'toggle');
  });

  // 2. 监听 下一曲
  globalShortcut.register('MediaNextTrack', () => {
    win.webContents.send('player-control', 'next');
  });

  // 3. 监听 上一曲
  globalShortcut.register('MediaPreviousTrack', () => {
    win.webContents.send('player-control', 'prev');
  });
});

app.on('will-quit', () => {
  // 必须在退出前注销所有快捷键
  globalShortcut.unregisterAll();
});
