TypeScript
import { defineStore } from 'pinia';
import { useHistoryStore } from './history';

export const useRecommendStore = defineStore('recommend', {
  state: () => ({
    aiTags: [] as string[], // 用户偏好的风格标签
    recommendations: [] as any[]
  }),
  actions: {
    // 分析用户口味
    analyzeUserTaste() {
      const historyStore = useHistoryStore();
      const artists = historyStore.list.map(t => t.ar[0].name);
      
      // 简单的频率计数
      const counts = artists.reduce((acc: any, name) => {
        acc[name] = (acc[name] || 0) + 1;
        return acc;
      }, {});
      
      // 提取用户最常听的前 3 位歌手作为 AI 搜索基准
      this.aiTags = Object.keys(counts)
        .sort((a, b) => counts[b] - counts[a])
        .slice(0, 3);
    }
  }
});
