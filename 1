开始接入本地音乐文件的扫描功能

编码助手
接入本地音乐扫描功能是 Electron 应用展现“本地权力”的时刻。这需要 Main Process（主进程） 调用 Node.js 的文件系统能力，并使用 music-metadata 等库解析音频文件的 ID3 信息（封面、标题、艺术家）。

🛠️ 第一步：安装核心解析库
由于音乐文件（MP3, FLAC）的信息存储在二进制 Meta 标签中，我们需要专业的库来读取。

Bash
# 在项目根目录安装
npm install music-metadata
🏗️ 第二步：主进程逻辑 (Service Layer)
在 Electron 主进程中（src/main/index.ts），我们需要添加一个对话框让用户选择文件夹，并递归扫描音频文件。

TypeScript
import { ipcMain, dialog } from 'electron';
import fs from 'fs';
import path from 'path';
import * as mm from 'music-metadata';

// 监听渲染进程发出的“选择目录”请求
ipcMain.handle('scan-local-music', async () => {
  const { canceled, filePaths } = await dialog.showOpenDialog({
    properties: ['openDirectory']
  });

  if (canceled) return [];

  const dirPath = filePaths[0];
  return await scanDir(dirPath);
});

async function scanDir(dirPath: string) {
  const files = fs.readdirSync(dirPath);
  const musicList = [];

  for (const file of files) {
    const fullPath = path.join(dirPath, file);
    const stat = fs.statSync(fullPath);

    if (stat.isDirectory()) {
      // 递归扫描子目录 (可选)
      // musicList.push(...await scanDir(fullPath));
    } else if (/\.(mp3|flac|wav|ogg)$/i.test(file)) {
      try {
        const metadata = await mm.parseFile(fullPath);
        // 将图片 Buffer 转换为 Base64 供前端显示
        let cover = '';
        if (metadata.common.picture && metadata.common.picture[0]) {
          const pic = metadata.common.picture[0];
          cover = `data:${pic.format};base64,${pic.data.toString('base64')}`;
        }

        musicList.push({
          id: `local-${Date.now()}-${Math.random()}`,
          name: metadata.common.title || file,
          ar: [{ name: metadata.common.artist || '未知歌手' }],
          al: { name: metadata.common.album || '本地专辑', picUrl: cover },
          url: `file://${fullPath}`, // Electron 支持 file:// 协议播放
          isLocal: true,
          path: fullPath
        });
      } catch (err) {
        console.error(`解析失败: ${fullPath}`, err);
      }
    }
  }
  return musicList;
}
