<script setup lang="ts">
import { ref, watch, computed } from 'vue';
import { usePlayerStore } from '../store/player';
import { storeToRefs } from 'pinia';

const playerStore = usePlayerStore();
const { lyric, currentTime } = storeToRefs(playerStore);
const lyricListRef = ref<HTMLElement | null>(null);

// 计算当前应该播放哪一行
const currentLyricIndex = computed(() => {
  return lyric.value.findIndex((line, index) => {
    const nextLine = lyric.value[index + 1];
    return currentTime.value >= line.time && (!nextLine || currentTime.value < nextLine.time);
  });
});

// 监听索引变化，实现自动滚动
watch(currentLyricIndex, (newIndex) => {
  if (newIndex !== -1 && lyricListRef.value) {
    const activeLine = lyricListRef.value.children[newIndex] as HTMLElement;
    if (activeLine) {
      // 将当前行滚动到容器中心
      lyricListRef.value.scrollTo({
        top: activeLine.offsetTop - lyricListRef.value.clientHeight / 2,
        behavior: 'smooth'
      });
    }
  }
});
</script>

