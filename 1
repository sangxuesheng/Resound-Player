 * 获取心动模式/智能播放列表
 * @param id 当前歌曲 ID
 * @param pid 歌单 ID（如果是从某个歌单开启的心动模式）
 */
export const getIntelligenceList = (id: number, pid: number = 0) => {
  return request.get('/playmode/intelligence/list', { 
    params: { id, pid, sid: id } 
  });
};
🏗️ 第二步：升级 Store 逻辑 (Controller 层)
我们需要在 player.ts 中增加一个处理“动态扩充队列”的动作。当心动模式开启且歌曲播放结束时，自动“预加载”下一批 AI 推荐的歌曲。

TypeScript
export const usePlayerStore = defineStore('player', {
  state: () => ({
    // ...
    isHeartbeatMode: false, // 是否开启心动模式
  }),
  
  actions: {
    async toggleHeartbeat() {
      this.isHeartbeatMode = !this.isHeartbeatMode;
      if (this.isHeartbeatMode && this.currentTrack) {
        await this.loadMoreIntelligence();
      }
    },

    async loadMoreIntelligence() {
      if (!this.currentTrack) return;
      
      try {
        const { data } = await getIntelligenceList(this.currentTrack.id);
        // 过滤掉已经在列表中的歌曲
        const newTracks = data.data
          .map((item: any) => item.songInfo)
          .filter((track: any) => !this.playlist.find(t => t.id === track.id));
        
        // 将 AI 推荐的歌曲追加到播放队列末尾
        this.playlist.push(...newTracks);
      } catch (error) {
        console.error("心动模式加载失败", error);
      }
    },

    // 修改原来的 next 方法
    async next() {
      if (this.playlist.length === 0) return;
      
      let nextIndex = this.currentIndex + 1;
      
      // 如果开启了心动模式，且快播放到列表末尾了，自动加载下一批
      if (this.isHeartbeatMode && nextIndex >= this.playlist.length - 2) {
        await this.loadMoreIntelligence();
      }

      if (nextIndex >= this.playlist.length) nextIndex = 0;
      
      this.currentIndex = nextIndex;
      this.playTrack(this.playlist[this.currentIndex]);
    }
  }
});
