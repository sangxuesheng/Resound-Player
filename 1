<script setup lang="ts">
import { ref, watch } from 'vue';
import { getQRKey, createQR, checkQRStatus } from '../api/auth';
import { useUserStore } from '../store/user';

const visible = ref(false);
const qrImg = ref('');
const statusMsg = ref('');
const loading = ref(false);
const userStore = useUserStore();
let timer: any = null;

const startLogin = async () => {
  loading.value = true;
  const { data: { data: { unikey } } } = await getQRKey();
  const { data: { data: { qrimg } } } = await createQR(unikey);
  qrImg.value = qrimg;
  loading.value = false;

  // 开始轮询
  timer = setInterval(async () => {
    const { data: statusRes } = await checkQRStatus(unikey);
    if (statusRes.code === 801) statusMsg.value = "等待扫码...";
    if (statusRes.code === 802) statusMsg.value = "已扫码，请在手机确认";
    if (statusRes.code === 803) {
      clearInterval(timer);
      statusMsg.value = "登录成功！";
      await userStore.checkStatus(); // 更新全局用户信息
      visible.value = false;
    }
  }, 3000);
};

defineExpose({ open: () => { visible.value = true; startLogin(); } });
</script>
