<script setup lang="ts">
import { ref, computed, onUnmounted } from 'vue';
import { Checked } from '@element-plus/icons-vue';
import { getQRKey, createQR, checkQRStatus } from '../../api/auth';
import { useUserStore } from '../../store/user';

const isOpen = ref(false);
const loading = ref(false);
const qrImg = ref('');
const status = ref(0); // 801, 802, 803, 800
const isExpired = computed(() => status.value === 800);
const userStore = useUserStore();

let timer: any = null;

const statusText = computed(() => {
  if (status.value === 801) return '等待扫码中...';
  if (status.value === 802) return '待手机端确认...';
  if (status.value === 803) return '登录成功，正在跳转';
  if (status.value === 800) return '二维码已过期';
  return '加载中...';
});

const statusColor = computed(() => {
  if (status.value === 801) return 'bg-yellow-500';
  if (status.value === 802) return 'bg-blue-500';
  if (status.value === 803) return 'bg-green-500';
  return 'bg-neutral-600';
});

const open = () => {
  isOpen.value = true;
  refreshQR();
};

const close = () => {
  isOpen.value = false;
  clearInterval(timer);
};

const refreshQR = async () => {
  loading.value = true;
  status.value = 0;
  try {
    const { data: { data: { unikey } } } = await getQRKey();
    const { data: { data: { qrimg } } } = await createQR(unikey);
    qrImg.value = qrimg;
    loading.value = false;
    startCheck(unikey);
  } catch (e) {
    loading.value = false;
  }
};

const startCheck = (key: string) => {
  clearInterval(timer);
  timer = setInterval(async () => {
    const { data: res } = await checkQRStatus(key);
    status.value = res.code;

    if (res.code === 803) {
      clearInterval(timer);
      await userStore.checkStatus(); // 获取用户信息和歌单
      setTimeout(() => close(), 1500);
    } else if (res.code === 800) {
      clearInterval(timer);
    }
  }, 3000);
};

onUnmounted(() => clearInterval(timer));
defineExpose({ open });
</script>

