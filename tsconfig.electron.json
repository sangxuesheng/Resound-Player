{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "outDir": ".tsc-out",
    "rootDir": "electron",
    "declaration": false,
    "sourceMap": false,
    "skipLibCheck": true
  },
  "include": ["electron/services/**/*.ts"]
}