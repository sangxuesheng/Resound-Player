# Gemini Music — Frontend Docker Image
# Multi-stage: build Vue app with Node, serve with Nginx
#
# Build:
#   docker build -f deploy/Dockerfile.frontend -t gemini-music-frontend .
#
# Run:
#   docker run -p 80:80 gemini-music-frontend

# ── Build stage ──
FROM node:22-alpine AS builder

WORKDIR /app

COPY package*.json package-lock.json ./
RUN rm -f package-lock.json && \
    sed -i 's|"@applemusic-like-lyrics/core": "file:_amll_dist/core/applemusic-like-lyrics-core-0.4.2.tgz"|"@applemusic-like-lyrics/core": "^0.4.2"|g' package.json && \
    sed -i 's|"@applemusic-like-lyrics/vue": "file:_amll_dist/vue/applemusic-like-lyrics-vue-0.4.2.tgz"|"@applemusic-like-lyrics/vue": "^0.4.2"|g' package.json && \
    npm install

COPY . .
ARG VITE_BASE_URL=/
ENV VITE_BASE_URL=$VITE_BASE_URL
RUN npm run build:web

# ── Production stage ──
FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html
COPY deploy/docker-nginx.conf /etc/nginx/nginx.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
LABEL org.opencontainers.image.title="Gemini Music Frontend"
LABEL org.opencontainers.image.description="Gemini Music 网页版前端 - Nginx + Vue 3 SPA"
LABEL org.opencontainers.image.version="0.1.0"