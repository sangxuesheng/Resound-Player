# Gemini Music — Unblock Services Docker Image
# Runs both unblock proxy (port 38762) and unblock match server (port 38763)
#
# Build:
#   docker build -f deploy/Dockerfile.unblock -t gemini-music-unblock .
#
# Run:
#   docker run -p 38762:38762 -p 38763:38763 gemini-music-unblock

FROM node:22-alpine

WORKDIR /app

RUN apk add --no-cache python3 make g++

COPY package*.json package-lock.json ./
RUN rm -f package-lock.json && \
    sed -i 's|"@applemusic-like-lyrics/core": "file:_amll_dist/core/applemusic-like-lyrics-core-0.4.2.tgz"|"@applemusic-like-lyrics/core": "^0.4.2"|g' package.json && \
    sed -i 's|"@applemusic-like-lyrics/vue": "file:_amll_dist/vue/applemusic-like-lyrics-vue-0.4.2.tgz"|"@applemusic-like-lyrics/vue": "^0.4.2"|g' package.json && \
    npm install

COPY . .

ENV ENABLE_FLAC=true
ENV PORT=38763
ENV UNBLOCK_SOURCES=bodian,kugou,migu,qq,bilibili

EXPOSE 38762 38763

CMD sh -c "\
  node node_modules/@unblockneteasemusic/server/app.js -p 38762 -o bodian kugou migu qq bilibili -s & \
  node server/unblock-match-server.mjs & \
  wait \
"
LABEL org.opencontainers.image.title="Gemini Music Unblock"
LABEL org.opencontainers.image.description="Gemini Music 音源替换服务 - Unblock Proxy + Match Server"
LABEL org.opencontainers.image.version="0.1.0"